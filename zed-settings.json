{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "disable_ai": true,
  "theme": "Ayu Mirage",
  "vim_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "buffer_font_size": 13,
  "buffer_font_family": "Input Mono",
  "features": {
    "copilot": false
  },
  "restore_on_startup": "none",
  "relative_line_numbers": "enabled",
  "vim": {
    "use_smartcase_find": true
  }
}
